-- plan
CREATE TABLE plan (
  id SERIAL PRIMARY KEY,
  name VARCHAR(255) NOT NULL,
  description TEXT NOT NULL,
  image TEXT,

  pricing_breakfast NUMERIC(10,2) NOT NULL CHECK (pricing_breakfast >= 0),
  pricing_lunch NUMERIC(10,2) NOT NULL CHECK (pricing_lunch >= 0),
  pricing_dinner NUMERIC(10,2) NOT NULL CHECK (pricing_dinner >= 0),

  allowed_durations JSONB NOT NULL,

  created_at TIMESTAMP DEFAULT NOW(),
  updated_at TIMESTAMP DEFAULT NOW()
);


-- plan mealbox

CREATE TABLE plan_meal_box (
  id SERIAL PRIMARY KEY,

  plan_id INTEGER NOT NULL
    REFERENCES plan(id)
    ON DELETE CASCADE,

  meal_box_id INTEGER NOT NULL
    REFERENCES meal_box(id)
    ON DELETE RESTRICT,

  slot VARCHAR(10) NOT NULL
    CHECK (slot IN ('breakfast','lunch','dinner')),

  created_at TIMESTAMP DEFAULT NOW(),

  UNIQUE (plan_id, meal_box_id, slot)
);


-- plan meal item

CREATE TABLE plan_meal_box_item (
  id SERIAL PRIMARY KEY,

  plan_meal_box_id INTEGER NOT NULL
    REFERENCES plan_meal_box(id)
    ON DELETE CASCADE,

  meal_item_id INTEGER NOT NULL
    REFERENCES meal_item(id)
    ON DELETE RESTRICT,

  quantity NUMERIC(10,2) NOT NULL
    CHECK (quantity > 0),

  UNIQUE (plan_meal_box_id, meal_item_id)
);
